{
  "manifest_version": 3,
  "name": "Xtra Focus",
  "version": "1.0.0",
  "description": "Distraction blocker for X (Twitter): hide the feed, trends, suggestions, ads, Grok and more — you choose what stays.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Xtra Focus",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*", "https://mobile.twitter.com/*"],
      "run_at": "document_start",
      "js": ["src/defaults.js", "src/content.js"],
      "css": ["src/hide.css"]
    }
  ]
}
